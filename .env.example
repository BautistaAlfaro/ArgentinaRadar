# ═══════════════════════════════════════════════════════════════════════════
# ArgentinaRadar — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy this file to config/.env and fill in your values.
#   cp .env.example config/.env
#
# All variables listed here are OPTIONAL unless marked [REQUIRED].
# Defaults are shown in comments where applicable.
#
# Sections:
#   1. General
#   2. Auth / JWT
#   3. Telegram
#   4. Bluesky (AT Protocol)
#   5. Twitter / X API
#   6. AI / LLM Provider
#   7. Image Generation
#   8. Service URLs
#   9. Ingestion & Processing
#  10. Quality Scoring
#  11. Redis
#  12. Database
#  13. Hermes Bridge
#  14. Night Owl
#  15. Alerts
#  16. Misc / Advanced
# ═══════════════════════════════════════════════════════════════════════════


# ─── 1. General ──────────────────────────────────────────────────────────
# Environment: development | production | test
NODE_ENV=development

# API base URL for backend services (optional — defaults to localhost)
API_BASE_URL=http://localhost

# Vite frontend API base URL (optional — defaults to localhost)
VITE_API_BASE_URL=http://localhost

# Timezone for scheduling (default: America/Argentina/Buenos_Aires)
TIMEZONE=America/Argentina/Buenos_Aires


# ─── 2. Auth / JWT ───────────────────────────────────────────────────────
# [REQUIRED in production] Secret key for signing JWT tokens
JWT_SECRET=change-this-to-a-strong-random-secret

# JWT access token expiry (default: 15m)
JWT_EXPIRES_IN=15m

# Refresh token expiry (default: 7d)
REFRESH_TOKEN_EXPIRES_IN=7d


# ─── 3. Telegram ─────────────────────────────────────────────────────────
# [REQUIRED] Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# [REQUIRED] Target Telegram chat/channel ID
TELEGRAM_CHAT_ID=your_chat_id_here


# ─── 4. Bluesky (AT Protocol) ────────────────────────────────────────────
# Enable Bluesky publishing (default: true)
BSKY_ENABLED=true

# Bluesky handle (e.g. myhandle.bsky.social)
BSKY_IDENTIFIER=your_handle.bsky.social

# [REQUIRED if BSKY_ENABLED=true] Bluesky app password (not main password!)
BSKY_APP_PASSWORD=your_app_password_here


# ─── 5. Twitter / X API ──────────────────────────────────────────────────
# Twitter API v2 credentials (legacy — Bluesky is the primary channel)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Daily tweet limit (default: 20)
DAILY_TWEET_LIMIT=20

# Tweet cooldown in ms (default: 300000 = 5 min)
TWEET_COOLDOWN_MS=300000

# Short URL service token (optional)
BITLY_ACCESS_TOKEN=


# ─── 6. AI / LLM Provider ───────────────────────────────────────────────
# Provider: ollama | openai | openrouter (default: ollama)
AI_PROVIDER=ollama

# AI mode: local (Ollama), openai, or hybrid (default: local)
AI_MODE=local

# ── OpenAI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ── OpenRouter ───────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=mistralai/mistral-nemo

# ── Ollama (local) ───────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_HOST=localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Local model overrides (defaults in comments)
LOCAL_MODEL_FAST=gemma3:4b
LOCAL_MODEL_SMART=qwen2.5:7b
LOCAL_MODEL_EMBED=nomic-embed-text

# ── AI Model selection ───────────────────────────────────────────────────
NER_MODEL=gpt-4o-mini
FILTER_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
FALLBACK_MODEL=google/gemini-2.0-flash-lite-preview-02-05:free
EMBEDDING_DIMENSIONS=1536

# ── Cost & Rate Limits ───────────────────────────────────────────────────
DAILY_BUDGET=2.00
RATE_LIMIT_RPM=10
MAX_BATCH_SIZE=20

# Per-model pricing (USD per 1M tokens) — do not change unless OpenAI/OpenRouter prices change
NER_INPUT_PRICE_PER_1M=0.150
NER_OUTPUT_PRICE_PER_1M=0.600
EMBEDDING_PRICE_PER_1M=0.020
FALLBACK_INPUT_PRICE_PER_1M=0.075
FALLBACK_OUTPUT_PRICE_PER_1M=0.300


# ─── 7. Image Generation ─────────────────────────────────────────────────
# Enable image generation (default: true)
IMAGE_GEN_ENABLED=true

# Image generation provider: pollinations | dall-e | openai (default: pollinations)
IMAGE_GEN_PROVIDER=pollinations

# Image gen model (default: dall-e-3)
IMAGE_GEN_MODEL=dall-e-3

# Size (default: 1024x1024)
IMAGE_GEN_SIZE=1024x1024

# Quality: standard | hd (default: standard)
IMAGE_GEN_QUALITY=standard

# Generation style: nanobanana | news | minimal | flag (default: nanobanana)
IMAGE_GEN_STYLE=nanobanana

# Minimum event impact threshold to auto-generate images (0-100)
IMAGE_GEN_IMPACT_THRESHOLD=80

# Image gen cost (USD, default: 0.04 standard / 0.08 HD)
IMAGE_GEN_COST_STANDARD=0.04
IMAGE_GEN_COST_HD=0.08

# Google AI Studio API key for image generation (NanoBanana)
GOOGLE_API_KEY=

# Brand colors (defaults: #003087 / #FFD700)
BRAND_PRIMARY=#003087
BRAND_GOLD=#FFD700

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173


# ─── 8. Service URLs ─────────────────────────────────────────────────────
# Internal service URLs (change if services run on different hosts)
AI_PROCESSOR_URL=http://localhost:3013
NEWS_SERVICE_URL=http://localhost:3001
GEOLOCATION_URL=http://localhost:3002
EVENT_DETECTOR_URL=http://localhost:3008
TWITTER_PUBLISHER_URL=http://localhost:3004
HERMES_ALERT_URL=http://localhost:3005/api/alerts

# AI API endpoint override (optional, falls back to AI_PROCESSOR_URL)
AI_API=

# Geo API endpoint override (optional, falls back to GEOLOCATION_URL)
GEO_API=


# ─── 9. Ingestion & Processing ──────────────────────────────────────────
# How often to poll news sources (ms, default: 300000 = 5 min)
INGESTION_INTERVAL=300000

# Generic poll interval (ms, varies per service — default: 30000 or 60000)
POLL_INTERVAL=30000

# Processing loop interval (ms, default: 30000)
PROCESS_INTERVAL=30000

# Batch size for processing (default: 20)
BATCH_SIZE=20

# Max articles to process (0 = unlimited)
MAX_ARTICLES=0

# Source status filter (default: geolocated)
SOURCE_STATUS=geolocated

# Path to sources.json (default: data/sources.json)
SOURCES_PATH=

# Auto-translate articles (default: false)
AUTO_TRANSLATE=false

# Translation provider (default: google)
TRANSLATION_PROVIDER=google

# Auto-summarize articles (default: false)
AUTO_SUMMARIZE=false

# Rewrite headlines via AI (default: false)
REWRITE_HEADLINES=false

# Clustering interval (ms, default: 1800000 = 30 min)
CLUSTER_INTERVAL=1800000

# Clustering lookback window (hours, default: 2)
CLUSTER_WINDOW=2

# Event detector fallback poll interval (ms, default: 300000)
FALLBACK_POLL_INTERVAL=300000

# Analysis interval for trends (ms, default: 1800000 = 30 min)
ANALYSIS_INTERVAL=1800000


# ─── 10. Quality Scoring ─────────────────────────────────────────────────
# Auto-publish threshold: articles with impact >= this skip approval (0-100)
AUTO_PUBLISH_THRESHOLD=80

# Minimum quality score to keep article (0-100, default: 40)
MIN_QUALITY_THRESHOLD=40

# Minimum engagement prediction to boost (0-100, default: 30)
MIN_ENGAGEMENT_PREDICTION=30


# ─── 11. Redis ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0


# ─── 12. Database ────────────────────────────────────────────────────────
# SQLite database path (default: data/argentina-radar.db)
DB_PATH=

# Full PostgreSQL/MySQL connection string (alternative to DB_PATH)
DATABASE_URL=

# Database write mode: dual | sqlite | postgres (default: dual)
DB_MODE=dual


# ─── 13. Hermes Bridge ──────────────────────────────────────────────────
# Notification poll interval (seconds, default: 30)
NOTIFICATION_POLL_INTERVAL=30

# Alert poll interval (seconds, default: 60)
ALERT_POLL_INTERVAL=60

# Approval workflow polling (seconds, default: 5)
APPROVAL_POLL_INTERVAL=5

# Approval event polling (seconds, default: 60)
APPROVAL_EVENT_POLL_INTERVAL=60

# Approval auto-publish threshold (0-100, default: 70)
APPROVAL_AUTO_PUBLISH_THRESHOLD=70

# Watchdog health check interval (ms, default: 60000)
WATCHDOG_INTERVAL=60000

# Watchdog timeout per check (ms, default: 3000)
WATCHDOG_TIMEOUT=3000

# Auto-cleanup hour (24h, default: 3 = 3 AM)
AUTO_CLEANUP_HOUR=3

# Auto-backup interval (ms, default: 21600000 = 6 hours)
AUTO_BACKUP_INTERVAL=21600000

# Number of backups to keep (default: 7)
AUTO_BACKUP_KEEP=7

# Pipeline health check interval (ms, default: 900000 = 15 min)
PIPELINE_HEALTH_INTERVAL=900000


# ─── 14. Night Owl ──────────────────────────────────────────────────────
# Enable Night Owl scheduled processing (default: true)
NIGHT_OWL_ENABLED=true

# Budget per night for AI processing (USD, default: 1.00)
NIGHT_OWL_BUDGET_PER_NIGHT=1.00


# ─── 15. Alerts ─────────────────────────────────────────────────────────
# NASA FIRMS API key for wildfire data (default: OPEN_DATA_TOKEN for limited access)
FIRMS_API_KEY=OPEN_DATA_TOKEN

# OpenSky credentials for flight tracking (optional)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=


# ─── 16. Misc / Advanced ─────────────────────────────────────────────────
# Port overrides (normally set per-service in PM2 config)
# PORT=3001

# Admin dashboard port override (default: 3012)
ADMIN_PORT=3012

# Admin collector interval (ms, default: 3600000 = 1 hour)
COLLECTOR_INTERVAL=3600000

# Skip health checks in orchestrator (set to 1 to skip)
SKIP_HEALTH_CHECKS=0
