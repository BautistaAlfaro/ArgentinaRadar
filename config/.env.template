# ── AI Processor (ai-processor) ────────────────────────────────────────
# AI_PROVIDER selects the AI backend:
#   "ollama"     → Local Ollama (qwen2.5:7b, nomic-embed-text) — zero cost
#   "openai"     → OpenAI API (requires OPENAI_API_KEY)
#   "openrouter" → OpenRouter API (requires OPENROUTER_API_KEY)
AI_PROVIDER=ollama

# AI_MODE (legacy, used by openai_client.py for local/hybrid routing):
#   "local"  → Ollama (zero cost, no API key needed)       ← DEFAULT
#   "openai" → OpenAI / OpenRouter APIs (requires API keys)
#   "hybrid" → Ollama by default, falls back to paid API
AI_MODE=local

# Local Ollama models (only used when AI_PROVIDER=ollama or AI_MODE=local/hybrid)
# OLLAMA_HOST=localhost:11434
# OLLAMA_MODEL=qwen2.5:7b          # Classification model
# OLLAMA_EMBED_MODEL=nomic-embed-text # Embedding model (768d)
# LOCAL_MODEL_FAST=gemma3:4b       # Fast classification (legacy)
# LOCAL_MODEL_SMART=qwen2.5:7b     # Spanish NER, sentiment, summaries
# LOCAL_MODEL_EMBED=nomic-embed-text # Local embeddings (768d)

# Required only if AI_PROVIDER is "openai" or "openrouter":
# OPENAI_API_KEY=sk-your-key
# OPENROUTER_API_KEY=your_openrouter_key

# ── Other Services ────────────────────────────────────────────────────

# Bluesky (AT Protocol) — FREE
BSKY_ENABLED=true
BSKY_IDENTIFIER=argentinaradar.bsky.social
BSKY_APP_PASSWORD=your-app-password

# Twitter API v2 (paid — legacy)
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

# Telegram (Hermes bot)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# High-Impact Auto-Publish — articles with impact >= threshold bypass approval
AUTO_PUBLISH_THRESHOLD=80

# Optional: URL shortener
BITLY_ACCESS_TOKEN=your_bitly_token

# Auth / JWT
JWT_SECRET=change-to-a-secure-random-string-at-least-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Auto-Translation ──────────────────────────────────────────────────
# Enable automatic detection and translation of non-Spanish articles
AUTO_TRANSLATE=true
# TRANSLATION_PROVIDER=google  # "google" (free, no key) or "openai" (better quality, needs key)

# ── Headline Rewriter ───────────────────────────────────────────────────
# Rewrite article headlines for Bluesky using local Ollama (qwen2.5:7b)
REWRITE_HEADLINES=true

# ── AI Summarizer ─────────────────────────────────────────────────────
# Generate concise AI summaries for PUBLISHED articles (requires Ollama)
AUTO_SUMMARIZE=true

# ── Automations ──────────────────────────────────────────────────────
# Service Watchdog — health-checks every 60s, restarts down services
WATCHDOG_ENABLED=true
WATCHDOG_INTERVAL=60000

# Auto-Backup — backs up the DB every 6 hours, keeps last 7 copies
AUTO_BACKUP_ENABLED=true
AUTO_BACKUP_INTERVAL=21600000
AUTO_BACKUP_KEEP=7

# Auto-Cleanup — purges old data daily at 3:00 AM
AUTO_CLEANUP_ENABLED=true
AUTO_CLEANUP_HOUR=3

# Pipeline Health — monitors pipeline every 15 min, sends summary every 6h
PIPELINE_HEALTH_ENABLED=true
PIPELINE_HEALTH_INTERVAL=900000
