{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../../shared/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["src", "../../shared/types", "../../shared/gazetteer", "../../shared/geo"],
  "exclude": ["node_modules", "dist", "../../shared/utils"]
}
